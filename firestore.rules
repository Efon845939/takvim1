rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Smart Calendar & Scheduling SaaS Security Rules
     * Optimized for Public Booking Flow
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if true; // Public can get user profile for booking context
      allow list: if false;
      allow create, update, delete: if isOwner(userId);

      match /events/{eventId} {
        // ALLOW PUBLIC LIST FOR AVAILABILITY CHECKING (MVP constraint without Cloud Functions)
        allow list: if true; 
        allow get: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      match /bookingLinks/{linkId} {
        allow get: if true; // Public access for booking page
        allow list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      match /bookings/{bookingId} {
        allow create: if true; // Public can create a booking
        allow list: if true;   // Public can list to avoid double-booking
        allow get, update, delete: if isOwner(userId);
      }
    }
  }
}