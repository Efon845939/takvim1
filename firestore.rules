
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * V9 Security Rules - Public Availability Enabled
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Public can read basic profile and authorized roles can update
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isOwner(userId);

      match /events/{eventId} {
        // Essential: Allow public list/get for availability checks in /book pages
        allow list: if true; 
        allow get: if true;
        allow create, update, delete: if isOwner(userId);
      }

      match /bookingLinks/{linkId} {
        // Essential: Public access for shareable links
        allow get: if true;
        allow list: if true;
        allow create, update, delete: if isOwner(userId);
      }

      match /bookings/{bookingId} {
        // Essential: Public can book and verify slots
        allow create: if true;
        allow list: if true;
        allow get: if true;
        allow update, delete: if isOwner(userId);
      }
    }

    match /appointments/{appointmentId} {
      allow create: if true;
      allow list: if true;
      allow get: if true;
      allow update, delete: if isSignedIn();
    }
  }
}
