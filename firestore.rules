
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Smart Calendar & Scheduling SaaS Security Rules
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if true; // Public can get user profile for booking
      allow list: if false;
      allow create, update, delete: if isOwner(userId);

      match /events/{eventId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /bookingLinks/{linkId} {
        allow get: if true; // Public access for scan/link
        allow list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      match /bookings/{bookingId} {
        allow create: if true; // Public can create a booking
        allow get, list, update, delete: if isOwner(userId);
      }
    }
  }
}
